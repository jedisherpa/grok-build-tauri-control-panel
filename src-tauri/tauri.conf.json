{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Build Control Panel",
  "version": "0.1.0",
  "identifier": "ai.xai.grok-build-control-panel",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Grok Build Control Panel",
        "width": 1380,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "category": "DeveloperTool",
    "shortDescription": "ACP control panel for Grok Build",
    "longDescription": "Desktop control panel for multi-session Grok Build agent orchestration with MCP management.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/henry.w@example.net",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
